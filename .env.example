# Copy to ".env" in this folder (never commit .env). Restart Expo after changes.

# --- VideoSDK calls & live streams (required for production builds) ---
# Option A — Appwrite Function "videosdk-token" (see appwrite-functions/videosdk-token/).
# In Appwrite Console: Functions → videosdk-token → copy the HTTPS domain (…appwrite.run).
EXPO_PUBLIC_VIDEOSDK_TOKEN_URL=https://xxxxxxxxxxxx.appwrite.run

# Option B — Same Node server as video processing (server/server.js exposes GET /get-token).
# EXPO_PUBLIC_SERVER_URL=https://your-api.example.com
# EXPO_PUBLIC_PROCESSING_SERVER_URL=http://192.168.1.10:3001

# Optional: path override. Omit for defaults (root query for *.appwrite.run, /get-token otherwise).
# EXPO_PUBLIC_VIDEOSDK_TOKEN_PATH=

# Optional public VideoSDK API key (dashboard); app has a fallback if unset.
# EXPO_PUBLIC_VIDEOSDK_API_KEY=

# --- EAS / store builds ---
# Add the same EXPO_PUBLIC_VIDEOSDK_TOKEN_URL in Expo dashboard → Project → Environment variables
# or: npx eas secret:create --scope project --name EXPO_PUBLIC_VIDEOSDK_TOKEN_URL --value "https://…"
# Then run: eas build --profile production
