# VideoSDK — same values as https://app.videosdk.live/ (never commit real secrets)
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET_KEY=

# Mux (https://dashboard.mux.com) — video ingest + adaptive HLS
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Webhook signing secret from Mux dashboard (verify Mux-Signature)
MUX_WEBHOOK_SECRET=
# Optional: restrict browser upload CORS (Expo native uploads ignore this)
MUX_CORS_ORIGIN=*


# Appwrite server API key (scopes: databases.read + databases.write on your DB)
# Used by /api/mux/webhook and /api/mux/direct-upload verification
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=6854922e0036a1e8dee6
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=685494a1002f8417c2b2
APPWRITE_VIDEO_COLLECTION_ID=685494f9001c3ccb2ba2

# Expo app (.env at repo root) — Mux via Appwrite Function (optional; overrides need for this server’s /api/mux/direct-upload)
# EXPO_PUBLIC_USE_MUX=true
# EXPO_PUBLIC_MUX_DIRECT_UPLOAD_FUNCTION_ID=<your Appwrite function $id>
